# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# Override any settings.yaml value:
# Convention: TEMPORAL_KG_<SECTION>_<KEY>

TEMPORAL_KG_DATABASE_NEO4J_URI=URL
TEMPORAL_KG_DATABASE_NEO4J_USER=USER
TEMPORAL_KG_DATABASE_NEO4J_PASSWORD=PASSWORD

# Optional: override log level for local debugging
# TEMPORAL_KG_LOGGING_LEVEL=DEBUG
